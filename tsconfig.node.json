{
    "extends": "@electron-toolkit/tsconfig/tsconfig.node.json",
    "include": [
        "electron.vite.config.*",
        "src/main/env.d.ts",
        "src/main/**/*",
        "src/preload/**/*",
        "src/types/*"
    ],
    "compilerOptions": {
        "composite": true,
        "types": ["electron-vite/node"],
        "paths": {
            "@t/*": ["./src/types/*"]
        }
    }
}
